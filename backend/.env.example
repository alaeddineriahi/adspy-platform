# App
APP_NAME=AdSpy
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://adspy:adspy@localhost:5432/adspy

# Redis
REDIS_URL=redis://localhost:6379/0

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Auth (Clerk) — https://clerk.com
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# AI Provider — "groq" (free) or "anthropic" (paid)
AI_PROVIDER=groq
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Scraping (Bright Data) — https://brightdata.com
BRIGHTDATA_API_KEY=
BRIGHTDATA_CUSTOMER_ID=

# Storage (Cloudflare R2) — https://dash.cloudflare.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=adspy-media
R2_ENDPOINT=

# Payments — Konnect (primary) — https://konnect.network
KONNECT_API_KEY=
KONNECT_WALLET_ID=
KONNECT_SANDBOX=true

# Payments — Flouci (secondary) — https://flouci.com
FLOUCI_APP_TOKEN=
FLOUCI_APP_SECRET=
